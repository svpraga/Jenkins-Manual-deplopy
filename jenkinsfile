pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                echo "checking after added credentials"
                echo "checking after added githu api"
                echo "modified webhook"
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo 'Building the application...'
                // add your build commands here
                // e.g: sh 'mvn clean install' for Java
                // e.g: sh 'npm install' for Node.js
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
                // e.g: sh 'mvn test'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying application...'
                // add your deploy commands here
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}
